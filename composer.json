{
    "name": "apermo/apermo-notify",
    "description": "A WordPress apermo-notify plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Christoph Daum",
            "email": "me@christoph-daum.de"
        }
    ],
    "require": {
        "php": ">=8.1",
        "wearerequired/traduttore-registry": "^2.1"
    },
    "require-dev": {
        "apermo/apermo-coding-standards": "^3.0",
        "apermo/phpstan-wordpress-rules": "^0.2",
        "brain/monkey": "^2.6",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "yoast/phpunit-polyfills": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Apermo\\Notify\\": "src/",
            "apermo\\WPTools\\": "src/Lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apermo\\Notify\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse --memory-limit=1G",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "make-pot": "wp i18n make-pot . languages/apermo-notify.pot --domain=apermo-notify --exclude=vendor,tests,e2e,.ddev,node_modules"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
